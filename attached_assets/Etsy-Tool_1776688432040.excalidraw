    },
    {
      "id": "EmgoB1SJ5zNu7atko0UgB",
      "type": "text",
      "x": -1108.7997383828388,
      "y": 1193.7208896822117,
      "width": 185.7619253593618,
      "height": 169.23681883333583,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "ay",
      "roundness": null,
      "seed": 498436751,
      "version": 2232,
      "versionNonce": 1394612417,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1776575149612,
      "link": null,
      "locked": false,
      "text": "User Wants SAME photo for his\nproduct. Ai should replaces the\nproduct in the successor image with\nhis product's image(After some\nquestions to clarify and be most\nefficient and accurate). In this user\nselects the level of similarity in his\nmockup image he wants.\nMeans to say, that in this option,\nuser wants same product\nmockup/mockups, for his product.\nNow how much similarity, this should\nalso be controllable.",
      "fontSize": 10.41457346666682,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "User Wants SAME photo for his product. Ai should replaces the product in the successor image with his product's image(After some questions to clarify and be most efficient and accurate). In this user selects the level of similarity in his mockup image he wants.\nMeans to say, that in this option, user wants same product mockup/mockups, for his product. Now how much similarity, this should also be controllable.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "nZYmDQRN5RD9W3yeRNW9h",
      "type": "text",
      "x": -334.9186401365798,
      "y": 1205.7257932649338,
      "width": 185.5928066350791,
      "height": 176.4325350890593,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "az",
      "roundness": null,
      "seed": 1969697903,
      "version": 2560,
      "versionNonce": 1322411183,
      "isDeleted": false,
      "boundElements": [
        {
          "id": "9U9Sh6JFdCmqt6YdAz4Mc",
          "type": "arrow"
        }
      ],
      "updated": 1776575288194,
      "link": null,
      "locked": false,
      "text": "User wants Successor's IDEA to be\nimplemented for his similar product\nand in the next steps give the\nmultiple options(some questions to\nclarify and be most efficient and\naccurate), which include the\nsuggestions as well and option to\nget users idea if he have anything in\nhis mind and ai can process for that.\nMeans this option lets user create\nbest mockup/mockups, for user's\nproduct, based on the IDEA taken\nfrom the successors\nmockup/mockups.",
      "fontSize": 10.081859147946243,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "User wants Successor's IDEA to be implemented for his similar product and in the next steps give the multiple options(some questions to clarify and be most efficient and accurate), which include the suggestions as well and option to get users idea if he have anything in his mind and ai can process for that.\nMeans this option lets user create best mockup/mockups, for user's product, based on the IDEA taken from the successors mockup/mockups.",
      "autoResize": false,
      "lineHeight": 1.25
    },
