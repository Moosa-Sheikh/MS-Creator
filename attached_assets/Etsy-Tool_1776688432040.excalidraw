      "seed": 596919873,
      "version": 1902,
      "versionNonce": 1613962223,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1776576138385,
      "link": null,
      "locked": false,
      "text": "For this prompt creation process, in the setting\nthere will be system prompt space. This is just for\nthe additional instructions if we want to give.\n+\nFor its Brain, separate LLMs i want to use, by\npasting the API key from Open Router.\n+\nI could be adding claude skills type things, with claud,\nso i want separate claude special setup with toggle\non/off option. When its on, the open router gets off.",
      "fontSize": 7.635412199491495,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "For this prompt creation process, in the setting there will be system prompt space. This is just for the additional instructions if we want to give.\n+\nFor its Brain, separate LLMs i want to use, by pasting the API key from Open Router.\n+\nI could be adding claude skills type things, with claud, so i want separate claude special setup with toggle on/off option. When its on, the open router gets off.",
      "autoResize": false,
      "lineHeight": 1.25
    },
