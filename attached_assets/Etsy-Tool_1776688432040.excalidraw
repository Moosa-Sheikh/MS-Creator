      "y": 1700.969980493734,
      "width": 201.03930654719898,
      "height": 95.44265249364369,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
