    {
      "id": "S1mDl62EDSatff7sUpBqI",
      "type": "text",
      "x": -414.5154717101675,
      "y": 398.7595592652457,
      "width": 208.25543086407671,
      "height": 125.19102317024326,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aG",
      "roundness": null,
      "seed": 574516783,
      "version": 2044,
      "versionNonce": 1221176225,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1776575149612,
      "link": null,
      "locked": false,
      "text": "User gives sample mockup picked from\nsomewhere, relative/Experts taken/Perfect\nsample for it, and his product photo as well\nwhich otherwise he was giving in the option B\nbeside it, so here user have two types of\ninputs.\n\nE.g= Competitors crochet mockup of the cap,\nand now i want the 100% similar setup for my\ncrochet cap. Or want my mockup impressed by\nthis",
      "fontSize": 9.104801685108601,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "User gives sample mockup picked from somewhere, relative/Experts taken/Perfect sample for it, and his product photo as well which otherwise he was giving in the option B beside it, so here user have two types of inputs.\n\nE.g= Competitors crochet mockup of the cap, and now i want the 100% similar setup for my crochet cap. Or want my mockup impressed by this",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "4Ab26y8isNEz_JrzteyBe",
      "type": "text",
      "x": 1084.6593085568693,
      "y": 398.9650011839133,
      "width": 210.66819488380892,
      "height": 149.1327365283046,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aH",
      "roundness": null,
      "seed": 695059599,
      "version": 2900,
      "versionNonce": 1351022895,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1776575183730,
      "link": null,
      "locked": false,
      "text": "User wants to make the mockup in his style\nfrom scratch and submit only one photo, or\nmultiple photos so better understanding of\nthe user's product. \n\nProcess: Continue for the ai to make the\nmockup for user's simple product photo or\nthat photo could be the photo of the user\ntaken from the website where he got the\nlicense to sell in the market and then he wants\nthat mockup to be like a successful etsy\nmockup in his style after passing through this\nAI .",
      "fontSize": 9.17739917097259,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "User wants to make the mockup in his style from scratch and submit only one photo, or multiple photos so better understanding of the user's product. \n\nProcess: Continue for the ai to make the mockup for user's simple product photo or that photo could be the photo of the user taken from the website where he got the license to sell in the market and then he wants that mockup to be like a successful etsy mockup in his style after passing through this AI .",
      "autoResize": false,
      "lineHeight": 1.25
    },
