    {
      "id": "OzJdhb3Z6xrUSIsxWyJdb",
      "type": "text",
      "x": 34.299404356143896,
      "y": 1744.6321068856996,
      "width": 330.59410710370565,
      "height": 61.52362218490364,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0R",
      "roundness": null,
      "seed": 938520641,
      "version": 2815,
      "versionNonce": 336964897,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1776575149613,
      "link": null,
      "locked": false,
      "text": "This is the development phase of the prompt, Ai will ask all the\nneccessary questions, multiple choice is better, but with every\noption there is one user input option if he has any other opinion on\nthat question, and the ai suggestion.\n",
      "fontSize": 9.843779549584582,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "This is the development phase of the prompt, Ai will ask all the neccessary questions, multiple choice is better, but with every option there is one user input option if he has any other opinion on that question, and the ai suggestion.\n",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "BeydZ0afV5uayjppb37XS",
      "type": "text",
      "x": 53.57312964337598,
      "y": 1911.383545191541,
      "width": 330.59410710370565,
      "height": 147.65669324376873,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0S",
      "roundness": null,
      "seed": 1081276993,
      "version": 3233,
      "versionNonce": 637886721,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1776575149613,
      "link": null,
      "locked": false,
      "text": "Remember that the final prompt is the universal prompt which can be\nusable as the template. I am saying this because user has provided\nimage/images of the product and now he is here for the mockup,\nmeans he want his product to be arranged or displayed like he wants\nto be, and this process happens to grab his product image/images\nand then display those like he want in the mockup. For that model\nlisted below will be the one which can take the images and prompt\nso that, that model knows what to do with those images and for\nthat it has a prompt that we will make here.\nAgain i am telling that we are not making products from scratch,\nmodel like \"fal-ai/bytedance/seedream/v5/lite/edit\", can take\nproduct image/images, prompt and gives the result.",
      "fontSize": 9.843779549584582,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Remember that the final prompt is the universal prompt which can be usable as the template. I am saying this because user has provided image/images of the product and now he is here for the mockup, means he want his product to be arranged or displayed like he wants to be, and this process happens to grab his product image/images and then display those like he want in the mockup. For that model listed below will be the one which can take the images and prompt so that, that model knows what to do with those images and for that it has a prompt that we will make here.\nAgain i am telling that we are not making products from scratch, model like \"fal-ai/bytedance/seedream/v5/lite/edit\", can take product image/images, prompt and gives the result.",
      "autoResize": false,
      "lineHeight": 1.25
    },
