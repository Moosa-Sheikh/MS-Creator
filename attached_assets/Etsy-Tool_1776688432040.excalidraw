    {
      "id": "7sn8s14MVeZq5PQOJHErQ",
      "type": "text",
      "x": -27.914343032515262,
      "y": 2358.4735487970565,
      "width": 173.13468665771603,
      "height": 93.72659322358777,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "dashed",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0h",
      "roundness": null,
      "seed": 141846063,
      "version": 2010,
      "versionNonce": 1043182273,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1776575149613,
      "link": null,
      "locked": false,
      "text": "It is the enhancer, its. work is to point out\nthe words that needs detailed instructions\ninstead of simple words, so that a best\nprompt is achievable which exactly makes what\nuser wants. For that it highlights those words\nand then it gets replaced by the suggested\ndetailed explanation of that words. For e.g. A\nbeautiful car. What does beautiful means? Ai\nwill know nothing about that, here explanation\nis needed",
      "fontSize": 7.498127457887023,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "It is the enhancer, its. work is to point out the words that needs detailed instructions instead of simple words, so that a best prompt is achievable which exactly makes what user wants. For that it highlights those words and then it gets replaced by the suggested detailed explanation of that words. For e.g. A beautiful car. What does beautiful means? Ai will know nothing about that, here explanation is needed",
      "autoResize": false,
      "lineHeight": 1.25
    },
